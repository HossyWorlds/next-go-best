# ===== このファイルは雛形。`cp .env.example .env` してから値を埋める =====
# !! 実際の秘密情報は .env に書き、.env はコミットしない（.gitignore 済み）!!

# --- Database (docker-compose の postgres と一致させる) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=password
POSTGRES_DB=app
POSTGRES_PORT=5432

# golang-migrate / アプリが使う接続文字列
DATABASE_URL=postgres://app:password@localhost:5432/app?sslmode=disable

# --- API server ---
PORT=8080

# CORS は限定オリジンのみ許可（ワイルドカード禁止）
CORS_ALLOWED_ORIGINS=http://localhost:3000

# セッションCookie。本番では必ず true（HTTPS前提）
SESSION_COOKIE_SECURE=false
# セッション有効期限（時間）
SESSION_TTL_HOURS=72
